# Code d'accès partagé avec les invités (choisi par Lemer Pax — ne pas inventer)
ACCESS_CODE=

# Secret de signature des cookies de session — 32 caractères minimum.
# Générer avec : openssl rand -base64 48
SESSION_SECRET=

# Token Vercel Blob (store PUBLIC requis — le mode est fixé à la création du store).
# Obtenir via : vercel blob create-store galerie-sofra --access public
# puis : vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=
